<EntityForm xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:dummy="0" flexi="1" fleximode="2" fullscreen="0" resize="0" version="2" layoutstrict="1" singlecardexpand="0" pagesposition="1" pageiconposition="0">
  <IsContactForm>false</IsContactForm>
  <EntityName>lead</EntityName>
  <CamelCase>Lead</CamelCase>
  <IsBulkUpdateForm>false</IsBulkUpdateForm>
  <CacheMode>-1</CacheMode>
  <UiSyncGuardMode>-1</UiSyncGuardMode>
  <PrimaryCommands>!defcmd</PrimaryCommands>
  <EnabledWorkflows>OnLoadEnabled OnChangeEnabled OnSaveEnabled OnExecuteCommand OnCanExecuteCommand</EnabledWorkflows>
  <SerializedChildrenV2>
    <FormTab xsi:type="DetailTab" flexiHeader="2" NameModified="1" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\General@2x.png" IsIconNameReadOnly="0">
      <Name>DETAILS</Name>
      <SerializedChildren>
        <DetailItem SchemaName="$Table1" grid="true">
          <Columns>*;*</Columns>
          <Rows>Auto;Auto;Auto;Auto;Auto;Auto;Auto</Rows>
          <Items>
            <DetailItem SchemaName="subject">
              <GridPosition>0;0;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="companyname">
              <GridPosition>0;1;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="firstname">
              <GridPosition>0;2;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="lastname">
              <GridPosition>1;2;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="emailaddress1">
              <GridPosition>0;3;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="mobilephone">
              <GridPosition>0;4;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="telephone1">
              <GridPosition>1;4;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="estimatedamount">
              <GridPosition>0;5;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="estimatedclosedate">
              <GridPosition>1;5;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="leadqualitycode" Style="Rating Horizontal RadioButton">
              <GridPosition>0;6;2;1</GridPosition>
            </DetailItem>
          </Items>
        </DetailItem>
      </SerializedChildren>
    </FormTab>
    <FormTab xsi:type="DetailTab" flexi="1" flexiHeader="2" NameModified="1" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\General@2x.png" IsIconNameReadOnly="0">
      <Name>ADDRESS</Name>
      <SerializedChildren>
        <DetailItem SchemaName="$Table2" grid="true">
          <Columns>*;*</Columns>
          <Rows>Auto;Auto;Auto;Auto;Auto</Rows>
          <Items>
            <DetailItem SchemaName="address1_line1">
              <GridPosition>0;0;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_line2">
              <GridPosition>0;1;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_line3">
              <GridPosition>0;2;2;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_city">
              <GridPosition>0;3;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_postalcode">
              <GridPosition>1;3;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_stateorprovince">
              <GridPosition>0;4;1;1</GridPosition>
            </DetailItem>
            <DetailItem SchemaName="address1_country">
              <GridPosition>1;4;1;1</GridPosition>
            </DetailItem>
          </Items>
        </DetailItem>
      </SerializedChildren>
    </FormTab>
    <FormTab xsi:type="MapTab" flexiHeight="450px" flexiHeader="0" NameModified="0" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\Map@2x.png" IsIconNameReadOnly="0">
      <Name>Map</Name>
      <CoordinatesBinding>address1_latitude;address1_longitude</CoordinatesBinding>
    </FormTab>
    <FormTab xsi:type="AssociatedTab" flexi="0" flexiHeight="6" flexiHeader="2" NameModified="1" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\activity@2x.png" IsIconNameReadOnly="0" DocCommands="0">
      <Name>ACTIVITIES</Name>
      <CustomName>ACTIVITIES</CustomName>
      <Binding SchemaName="activity.regardingobjectid"/>
      <Views>@activity.*:activity.@My Activities:appointment.*:email.*:phonecall.*:serviceappointment.*:task.*</Views>
    </FormTab>
    <FormTab xsi:type="AssociatedTab" flexi="0" flexiHeight="6" flexiHeader="2" NameModified="1" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\annotation@2x.png" IsIconNameReadOnly="0">
      <Name>NOTES</Name>
      <CustomName>NOTES</CustomName>
      <Binding SchemaName="annotation.objectid"/>
    </FormTab>
  </SerializedChildrenV2>
  <FormPages>
    <FormPages layoutstrict="1" singlecardexpand="0" fleximode="2" iconposition="0">
      <Name>DETAILS</Name>
      <IconName></IconName>
      <TabIndexes>
        <int>0</int>
        <int>1</int>
        <int>2</int>
      </TabIndexes>
    </FormPages>
    <FormPages layoutstrict="1" singlecardexpand="0" fleximode="0" iconposition="0">
      <Name>ACTIVITIES + NOTES</Name>
      <IconName></IconName>
      <TabIndexes>
        <int>3</int>
        <int>4</int>
      </TabIndexes>
    </FormPages>
  </FormPages>
</EntityForm>
    <FormTab xsi:type="AssociatedTab" flexiHeight="6" flexiHeader="2" NameModified="1" IconModified="0" EntityIconName="MobileCrm\Images.MonoTouch\Tabs\annotation@2x.png" IsIconNameReadOnly="0">
      <Name>NOTES</Name>
      <CustomName>NOTES</CustomName>
      <Binding SchemaName="annotation.objectid"/>
    </FormTab>
  </SerializedChildrenV2>
  <FormPages>
